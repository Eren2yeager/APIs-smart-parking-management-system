# AI backend server
AI_BACKEND_HOST=0.0.0.0
AI_BACKEND_PORT=8000
AI_BACKEND_LOG_LEVEL=INFO


# Roboflow API
ROBOFLOW_API_KEY=your_roboflow_api_key
ROBOFLOW_WORKSPACE=your_workspace
ROBOFLOW_LICENSE_PLATE_PROJECT=license-plate-detection
ROBOFLOW_LICENSE_PLATE_VERSION=1
ROBOFLOW_PARKING_SLOT_PROJECT=parking-slot-detection
ROBOFLOW_PARKING_SLOT_VERSION=1

# Detection thresholds (percent 0–100 for plate/slot in pipeline)
PLATE_DETECTION_CONFIDENCE=20
PARKING_SLOT_CONFIDENCE=20
VEHICLE_DETECTION_CONFIDENCE=50

# Frame processing
GATE_FRAME_SKIP=10
LOT_FRAME_SKIP=20
DUPLICATE_DETECTION_WINDOW=10

# Next.js (AI backend calls these to push entry/exit/capacity)
NEXTJS_API_URL=http://localhost:3000
NEXTJS_WEBHOOK_ENTRY=/api/ai/webhook/entry
NEXTJS_WEBHOOK_EXIT=/api/ai/webhook/exit
NEXTJS_WEBHOOK_CAPACITY=/api/ai/webhook/capacity
NEXTJS_WEBHOOK_TIMEOUT_SECONDS=30

# Shared secret (must match AI_WEBHOOK_SECRET in next.js-work/.env.local)
AI_WEBHOOK_SECRET=12344321

# Performance
MAX_CONCURRENT_STREAMS=10
BUFFER_SIZE=100
