# ============================================
# AI Backend Server Configuration
# ============================================
AI_BACKEND_HOST=0.0.0.0
AI_BACKEND_PORT=8000
AI_BACKEND_LOG_LEVEL=INFO

# ============================================
# Roboflow Workflow API Configuration
# ============================================
# SECURITY: Never commit your actual API key to Git!
# Get your API key from: https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=your_roboflow_api_key_here
ROBOFLOW_WORKSPACE=your_workspace_name

# Workflow IDs (from your Roboflow workspace)
# Find them at: https://app.roboflow.com/workflows
ROBOFLOW_LICENSE_PLATE_WORKFLOW_ID=find-license-plates
ROBOFLOW_PARKING_SLOT_WORKFLOW_ID=find-parked-vehicles-and-empty-parking-slots

# ============================================
# Detection Confidence Thresholds (0-100)
# ============================================
# Lower values = more detections (may include false positives)
# Higher values = fewer detections (may miss some objects)
PLATE_DETECTION_CONFIDENCE=20
PARKING_SLOT_CONFIDENCE=20

# ============================================
# Frame Processing Configuration
# ============================================
# Process every Nth frame to reduce load
# RECOMMENDED: Higher values for better performance
# - GATE_FRAME_SKIP=30 means process 1 frame per second at 30 FPS
# - LOT_FRAME_SKIP=60 means process 0.5 frames per second at 30 FPS
GATE_FRAME_SKIP=30
LOT_FRAME_SKIP=60
DUPLICATE_DETECTION_WINDOW=10

# ============================================
# Next.js Integration (Webhook Configuration)
# ============================================
NEXTJS_API_URL=http://localhost:3000
NEXTJS_WEBHOOK_ENTRY=/api/ai/webhook/entry
NEXTJS_WEBHOOK_EXIT=/api/ai/webhook/exit
NEXTJS_WEBHOOK_CAPACITY=/api/ai/webhook/capacity
NEXTJS_WEBHOOK_TIMEOUT_SECONDS=30

# Shared Webhook Secret
# PRODUCTION: Use a strong random secret (min 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This MUST match AI_WEBHOOK_SECRET in your Next.js .env.local file
AI_WEBHOOK_SECRET=your_secure_random_secret_here_min_32_chars

# ============================================
# Performance Configuration
# ============================================
MAX_CONCURRENT_STREAMS=10
BUFFER_SIZE=100
